<UserControl x:Class="WinOptimizerHub.Views.SystemToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <TextBlock Style="{DynamicResource HeadingText}" Text="System Tools" Margin="0,0,0,4"/>
        <TextBlock Style="{DynamicResource SecondaryText}"
                   Text="Built-in Windows diagnostic and repair tools" Margin="0,0,0,20"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Diagnostic &amp; Repair" Style="{DynamicResource SubheadingText}" Margin="0,0,0,16"/>
                        <UniformGrid Rows="2" Columns="2">
                            <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,4,4" Click="RunSfc_Click"
                                    IsEnabled="{Binding ToolsEnabled}">
                                <StackPanel>
                                    <TextBlock Text="&#xE930;" FontFamily="{DynamicResource IconFont}" FontSize="28" HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="SFC /scannow" FontSize="12" Margin="0,8,0,2" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Scan and repair system files" Style="{DynamicResource MutedText}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{DynamicResource SecondaryButton}" Margin="4,0,0,4" Click="RunDismCheck_Click"
                                    IsEnabled="{Binding ToolsEnabled}">
                                <StackPanel>
                                    <TextBlock Text="&#xE9F5;" FontFamily="{DynamicResource IconFont}" FontSize="28" HorizontalAlignment="Center" Foreground="#22C55E"/>
                                    <TextBlock Text="DISM Check" FontSize="12" Margin="0,8,0,2" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Check component store health" Style="{DynamicResource MutedText}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,4,0" Click="RunDismRestore_Click"
                                    IsEnabled="{Binding ToolsEnabled}">
                                <StackPanel>
                                    <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="28" HorizontalAlignment="Center" Foreground="#8B5CF6"/>
                                    <TextBlock Text="DISM Restore" FontSize="12" Margin="0,8,0,2" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Restore health (needs internet)" Style="{DynamicResource MutedText}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{DynamicResource SecondaryButton}" Margin="4,0,0,0" Click="RunDefrag_Click"
                                    IsEnabled="{Binding ToolsEnabled}">
                                <StackPanel>
                                    <TextBlock Text="&#xEDA2;" FontFamily="{DynamicResource IconFont}" FontSize="28" HorizontalAlignment="Center" Foreground="#F59E0B"/>
                                    <TextBlock Text="Defrag / Optimize" FontSize="12" Margin="0,8,0,2" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Defragment selected drive" Style="{DynamicResource MutedText}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>
                <!-- Output -->
                <Border Style="{DynamicResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Output" Style="{DynamicResource SubheadingText}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{DynamicResource DangerButton}" Padding="10,4" FontSize="11"
                                        Margin="0,0,8,0"
                                        Command="{Binding AbortCommand}"
                                        Visibility="{Binding CanAbort, Converter={StaticResource BoolVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE711;" FontFamily="{DynamicResource IconFont}" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Abort"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{DynamicResource SecondaryButton}" Padding="10,4" FontSize="11"
                                        Margin="0,0,8,0" Command="{Binding ClearOutputCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Clear"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{DynamicResource SecondaryButton}" Padding="10,4" FontSize="11"
                                        Command="{Binding CopyOutputCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="{DynamicResource IconFont}" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Copy"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" Padding="12">
                            <ScrollViewer x:Name="OutputScroller"
                                          Height="260"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          CanContentScroll="True"
                                          Style="{DynamicResource ModernScrollViewer}">
                                <ItemsControl x:Name="OutputList"
                                              ItemsSource="{Binding OutputLines}"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}"
                                                       FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="NoWrap"
                                                       Margin="0,1,0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
            <!-- Quick Launch -->
            <Border Grid.Column="2" Style="{DynamicResource Card}">
                <StackPanel>
                    <TextBlock Text="Quick Launch" Style="{DynamicResource SubheadingText}" Margin="0,0,0,16"/>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenTaskManager_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xECF0;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Task Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenDeviceManager_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7F4;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#22C55E"/>
                            <TextBlock Text="Device Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenDiskMgmt_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEDA2;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#F59E0B"/>
                            <TextBlock Text="Disk Management" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenResourceMonitor_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE821;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#8B5CF6"/>
                            <TextBlock Text="Resource Monitor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenEventViewer_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#EF4444"/>
                            <TextBlock Text="Event Viewer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenRegedit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE805;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#06B6D4"/>
                            <TextBlock Text="Registry Editor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="OpenGpedit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEC7A;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#D946EF"/>
                            <TextBlock Text="Group Policy Editor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SecondaryButton}" HorizontalContentAlignment="Left" Click="OpenSysProperties_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE770;" FontFamily="{DynamicResource IconFont}" FontSize="16" Width="28" Foreground="#F59E0B"/>
                            <TextBlock Text="System Properties" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
