<UserControl x:Class="WinOptimizerHub.Views.FontCacheView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24">
        <TextBlock Style="{DynamicResource HeadingText}" Text="Font Cache Cleaner" Margin="0,0,0,4"/>
        <TextBlock Style="{DynamicResource SecondaryText}" Text="Rebuild the Windows Font Cache to fix font rendering issues" Margin="0,0,0,20"/>
        <Border Style="{DynamicResource Card}">
            <StackPanel HorizontalAlignment="Center" Margin="40">
                <TextBlock Text="&#xE8D2;" FontFamily="{DynamicResource IconFont}"
                           FontSize="72" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="{Binding CacheSize}"
                           FontSize="24" FontWeight="Bold" Margin="0,16,0,4"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding CacheFiles}"
                           Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                <TextBlock Text="Rebuilding the font cache will stop the FontCache service, delete cache files, and restart the service. This fixes blurry or missing fonts."
                           Style="{DynamicResource SecondaryText}" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="500" Margin="0,16,0,0"/>
                <Button Style="{DynamicResource PrimaryButton}" Margin="0,24,0,0"
                        Command="{Binding RebuildCommand}" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Rebuild Font Cache"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
