<UserControl x:Class="WinOptimizerHub.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
        <converters:StringToColorBrushConverter x:Key="StringBrush"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Service Optimizer"/>
                <TextBlock Text="{Binding SummaryText}" Style="{DynamicResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <Button Style="{DynamicResource SecondaryButton}" Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource PrimaryButton}" Command="{Binding ApplyRecommendationsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9F5;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Apply Recommendations"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Filter toolbar -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center" MinWidth="200" FontSize="13">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock Text="Search services..." Foreground="{DynamicResource TextMutedBrush}"
                                                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Border>
                <CheckBox Grid.Column="1" IsChecked="{Binding ShowOnlyOptimizable}"
                          Content="Show only optimizable" Style="{DynamicResource ModernCheckBox}"
                          VerticalAlignment="Center" Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- Services ListView -->
        <Border Style="{DynamicResource Card}">
            <ListView x:Name="ServiceList"
                      Style="{DynamicResource ModernListView}"
                      ItemContainerStyle="{DynamicResource ModernListViewItem}"
                      ItemsSource="{Binding Items}"
                      MaxHeight="460"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionChanged="ServiceList_SelectionChanged"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Item">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Set Automatic" Tag="Automatic" Click="ServiceContextMenu_Click"/>
                        <MenuItem Header="Set Manual"    Tag="Manual"    Click="ServiceContextMenu_Click"/>
                        <MenuItem Header="Set Disabled"  Tag="Disabled"  Click="ServiceContextMenu_Click"/>
                        <Separator/>
                        <MenuItem Header="Start Service" Tag="Start" Click="ServiceStartStop_Click"/>
                        <MenuItem Header="Stop Service"  Tag="Stop"  Click="ServiceStartStop_Click"/>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Status" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="7,2" Background="{DynamicResource BgSecondaryBrush}">
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{Binding StatusColor, Converter={StaticResource StringBrush}}"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Service Name" Width="200" DisplayMemberBinding="{Binding DisplayName}"/>
                        <GridViewColumn Header="Start Type" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartType}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Recommended" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RecommendedStartType}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Visibility="{Binding NeedsOptimization, Converter={StaticResource BoolVis}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Reason" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Recommendation}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               ToolTip="{Binding Recommendation}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{DynamicResource SecondaryButton}" Padding="8,3" FontSize="11"
                                            Click="ServiceApply_Click" Tag="{Binding}" Content="Apply"
                                            Visibility="{Binding NeedsOptimization, Converter={StaticResource BoolVis}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </StackPanel>
</UserControl>
