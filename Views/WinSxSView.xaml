<UserControl x:Class="WinOptimizerHub.Views.WinSxSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
        <converters:StringToColorBrushConverter x:Key="StringBrush"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
        <StackPanel Margin="24">
            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{DynamicResource HeadingText}" Text="WinSxS / Windows Cleanup"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding SizeText}" Style="{DynamicResource SecondaryText}"/>
                        <TextBlock Text=" — " Style="{DynamicResource SecondaryText}"
                                   Visibility="{Binding HasTotal, Converter={StaticResource BoolVis}}"/>
                        <TextBlock Text="{Binding TotalReclaimable}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Visibility="{Binding HasTotal, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Analyze"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Style="{DynamicResource PrimaryButton}"
                        Command="{Binding CleanWindowsUpdateDismCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="WU Cleanup (DISM)"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="5" Style="{DynamicResource DangerButton}"
                        Command="{Binding CleanCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Full Cleanup"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="7" Style="{DynamicResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsBusy}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8BB;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Progress -->
            <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                    <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
                </StackPanel>
            </Border>

            <!-- Cleanup cards 3x2 -->
            <Border Style="{DynamicResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- Update Cache -->
                    <Border Grid.Column="0" Grid.Row="0" Margin="0,0,8,8" CornerRadius="8" Padding="14" Background="{DynamicResource BgSecondaryBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE896;" FontFamily="{DynamicResource IconFont}" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <Border Background="#22C55E" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding UpdateCacheCard.IsCleaned, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="✓ Cleaned" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Windows Update Cache" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding UpdateCacheCard.SizeText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,4" FontSize="11" Command="{Binding CleanUpdateCacheCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"><TextBlock Text="Clean"/></Button>
                        </StackPanel>
                    </Border>
                    <!-- Delivery Optimization -->
                    <Border Grid.Column="1" Grid.Row="0" Margin="0,0,8,8" CornerRadius="8" Padding="14" Background="{DynamicResource BgSecondaryBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE753;" FontFamily="{DynamicResource IconFont}" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <Border Background="#22C55E" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding DeliveryOptCard.IsCleaned, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="✓ Cleaned" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Delivery Optimization" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding DeliveryOptCard.SizeText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,4" FontSize="11" Command="{Binding CleanDeliveryOptCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"><TextBlock Text="Clean"/></Button>
                        </StackPanel>
                    </Border>
                    <!-- Upgrade Logs -->
                    <Border Grid.Column="2" Grid.Row="0" Margin="0,0,0,8" CornerRadius="8" Padding="14" Background="{DynamicResource BgSecondaryBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE9F9;" FontFamily="{DynamicResource IconFont}" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <Border Background="#22C55E" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding UpgradeLogsCard.IsCleaned, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="✓ Cleaned" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Upgrade Logs" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding UpgradeLogsCard.SizeText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,4" FontSize="11" Command="{Binding CleanUpgradeLogsCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"><TextBlock Text="Clean"/></Button>
                        </StackPanel>
                    </Border>
                    <!-- WER -->
                    <Border Grid.Column="0" Grid.Row="1" Margin="0,0,8,0" CornerRadius="8" Padding="14" Background="{DynamicResource BgSecondaryBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE7BA;" FontFamily="{DynamicResource IconFont}" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <Border Background="#22C55E" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding WerCard.IsCleaned, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="✓ Cleaned" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Error Reports (WER)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding WerCard.SizeText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,4" FontSize="11" Command="{Binding CleanWerCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"><TextBlock Text="Clean"/></Button>
                        </StackPanel>
                    </Border>
                    <!-- DirectX Shader Cache -->
                    <Border Grid.Column="1" Grid.Row="1" Margin="0,0,8,0" CornerRadius="8" Padding="14" Background="{DynamicResource BgSecondaryBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE7F4;" FontFamily="{DynamicResource IconFont}" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <Border Background="#22C55E" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding DxCacheCard.IsCleaned, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="✓ Cleaned" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="DirectX Shader Cache" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding DxCacheCard.SizeText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,4" FontSize="11" Command="{Binding CleanDxCacheCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"><TextBlock Text="Clean"/></Button>
                        </StackPanel>
                    </Border>
                    <!-- Thumbnail Cache -->
                    <Border Grid.Column="2" Grid.Row="1" CornerRadius="8" Padding="14" Background="{DynamicResource BgSecondaryBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE8B9;" FontFamily="{DynamicResource IconFont}" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <Border Background="#22C55E" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding ThumbCacheCard.IsCleaned, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="✓ Cleaned" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Thumbnail Cache" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ThumbCacheCard.SizeText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,4" FontSize="11" Command="{Binding CleanThumbCacheCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"><TextBlock Text="Clean"/></Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Output log -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Output" Style="{DynamicResource SubheadingText}"/>
                        <Button HorizontalAlignment="Right" Style="{DynamicResource SecondaryButton}"
                                Padding="8,3" FontSize="11" Command="{Binding ClearOutputCommand}">
                            <TextBlock Text="Clear"/>
                        </Button>
                    </Grid>
                    <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" Padding="12">
                        <ScrollViewer x:Name="WinSxSScroller" MaxHeight="320" MinHeight="100"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding OutputLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="{Binding Color, Converter={StaticResource StringBrush}}"
                                                   FontFamily="{DynamicResource MonoFont}" FontSize="11" TextWrapping="NoWrap" Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
