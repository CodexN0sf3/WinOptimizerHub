<UserControl x:Class="WinOptimizerHub.Views.DiskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Disk Analyzer"/>
                <TextBlock Style="{DynamicResource SecondaryText}" Text="Visualize disk usage and find space hogs" Margin="0,4,0,0"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Path:" VerticalAlignment="Center" Style="{DynamicResource BodyText}"/>
            <TextBox Grid.Column="3" x:Name="DiskAnalyzePath" Text="C:\"
                     Style="{DynamicResource ModernTextBox}" VerticalAlignment="Center"/>
            <Button Grid.Column="5" Style="{DynamicResource PrimaryButton}" Click="AnalyzeDisk_Click"
                    IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Analyze"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Style="{DynamicResource Card}"
                Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolVis}}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource BodyText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <Border Style="{DynamicResource Card}"
                Visibility="{Binding HasFolders, Converter={StaticResource InvBoolVis}}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ℹ What does Disk Analyzer do?" Style="{DynamicResource SubheadingText}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Style="{DynamicResource SecondaryText}">Disk Analyzer scans the selected path and shows which folders consume the most space, sorted by size. This helps you identify space hogs quickly — large game folders, old downloads, log directories, or backup files you may have forgotten about.

After the analysis you can:
  • Sort by size to find the biggest offenders
  • Navigate to any folder directly in Explorer
  • Re-run the scan on a different path at any time

Tip: Start with C:\ for a full overview, or drill into a specific folder (e.g. C:\Users\YourName) for details.</TextBlock>
            </StackPanel>
        </Border>

        <!-- Drives overview -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Drives Overview" Style="{DynamicResource SubheadingText}" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Drives}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{DynamicResource SmallCard}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xEDA2;" FontFamily="{DynamicResource IconFont}"
                                               FontSize="24" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DriveLetter}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding VolumeLabel}" Margin="8,0,0,0" Style="{DynamicResource SecondaryText}"/>
                                            <TextBlock Text="{Binding FileSystem}" Margin="8,0,0,0" Style="{DynamicResource MutedText}"/>
                                        </StackPanel>
                                        <ProgressBar Value="{Binding UsagePercent, Mode=OneWay}" Maximum="100"
                                                     Style="{DynamicResource ThinProgressBar}" Margin="0,6,0,0"
                                                     Width="300" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                                            <Run Text="{Binding UsedDisplay, Mode=OneWay}"/>
                                            <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}"/>
                                            <Run Text="{Binding TotalDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding FreeDisplay, Mode=OneWay}" Style="{DynamicResource SecondaryText}" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Folder analysis -->
        <Border Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Folder Analysis" Style="{DynamicResource SubheadingText}" Margin="0,0,0,12"/>
                <ListView Style="{DynamicResource ModernListView}" ItemsSource="{Binding Folders}"
                          MaxHeight="380" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Folder" Width="240" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding SizeDisplay, Mode=OneWay}"/>
                            <GridViewColumn Header="Files" Width="80" DisplayMemberBinding="{Binding FileCount}"/>
                            <GridViewColumn Header="% of Parent" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PercentOfParent, StringFormat={}{0:F1}%}"
                                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <ProgressBar Value="{Binding PercentOfParent}" Maximum="100"
                                                         Style="{DynamicResource ThinProgressBar}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Path" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FullPath}" FontSize="11"
                                                   FontFamily="{DynamicResource MonoFont}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FullPath}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <TextBlock Visibility="{Binding HasFolders, Converter={StaticResource InvBoolVis}}"
                           Text="Enter a path and click Analyze"
                           Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,16"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
