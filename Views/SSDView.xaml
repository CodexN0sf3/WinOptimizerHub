<UserControl x:Class="WinOptimizerHub.Views.SSDView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
        <converters:StringToColorBrushConverter x:Key="StringBrush"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="SSD Tweaker"/>
                <TextBlock Text="{Binding SummaryText}" Style="{DynamicResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Check Status"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource PrimaryButton}"
                    Command="{Binding ApplyAllCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE9F5;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Apply Selected"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="5" Style="{DynamicResource SecondaryButton}"
                    Command="{Binding RevertAllCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE777;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Restore Defaults"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Progress -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Grouped items -->
        <Border Style="{DynamicResource Card}">
            <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GroupedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <Border BorderBrush="{Binding HeaderColor, Converter={StaticResource StringBrush}}"
                                        BorderThickness="0,0,0,2" Padding="0,0,0,6" Margin="0,4,0,8">
                                    <TextBlock Text="{Binding Header}" FontWeight="Bold" FontSize="13"
                                               Foreground="{Binding HeaderColor, Converter={StaticResource StringBrush}}"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{DynamicResource SmallCard}" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              Style="{DynamicResource ModernCheckBox}"
                                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Style="{DynamicResource SecondaryText}"
                                                                   Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                                                            Margin="12,0,8,0" VerticalAlignment="Center"
                                                            Background="{Binding StatusColor, Converter={StaticResource StringBrush}, ConverterParameter=20}">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusColor, Converter={StaticResource StringBrush}}"/>
                                                    </Border>
                                                    <Button Grid.Column="3" Style="{DynamicResource PrimaryButton}"
                                                            Padding="10,4" FontSize="11"
                                                            Click="ApplySSDTweak_Click" Tag="{Binding}"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsCurrentlyOptimal, Converter={StaticResource InvBoolVis}}">
                                                        <TextBlock Text="Apply"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
