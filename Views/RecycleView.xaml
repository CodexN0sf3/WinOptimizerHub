<UserControl x:Class="WinOptimizerHub.Views.RecycleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24">
        <TextBlock Style="{DynamicResource HeadingText}" Text="Recycle Bin Cleaner" Margin="0,0,0,4"/>
        <TextBlock Style="{DynamicResource SecondaryText}" Text="View and empty the Windows Recycle Bin" Margin="0,0,0,20"/>
        <Border Style="{DynamicResource Card}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}"
                           FontSize="72" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="{Binding BinSize}"
                           FontSize="28" FontWeight="Bold" Margin="0,16,0,4"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding BinCount}"
                           Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                <Button Style="{DynamicResource DangerButton}" Margin="0,24,0,0"
                        Command="{Binding EmptyCommand}" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}"
                                   FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Empty Recycle Bin"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
