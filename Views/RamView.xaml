<UserControl x:Class="WinOptimizerHub.Views.RamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
        <converters:PercentToHeightConverter x:Key="PercentToHeight"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="RAM Optimizer"/>
                <TextBlock Text="{Binding RamDetail}" Style="{DynamicResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource PrimaryButton}"
                    Command="{Binding OptimizeCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE950;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Optimize All"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource SecondaryButton}"
                    Command="{Binding OptimizeSelectedCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE762;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Optimize Selected"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: stats + history -->
            <StackPanel>
                <Border Style="{DynamicResource Card}" Margin="0,0,0,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Memory Usage" Style="{DynamicResource SubheadingText}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Border Width="140" Height="140" CornerRadius="70"
                                Background="{DynamicResource BgCardHoverBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding RamUsedGb, StringFormat={}{0:F1}}"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="GB Used" Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ProgressBar Style="{DynamicResource ModernProgressBar}" Maximum="100"
                                     Value="{Binding RamPercent, Mode=OneWay}" Foreground="#8B5CF6"/>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding RamDetail}" Style="{DynamicResource SecondaryText}"/>
                            <TextBlock Text=" — " Style="{DynamicResource SecondaryText}"/>
                            <TextBlock Text="{Binding RamFreeText}" Foreground="#22C55E" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource Card}">
                    <StackPanel>
                        <TextBlock Text="Usage History (2 min)" Style="{DynamicResource SubheadingText}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding History}" Height="80">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="3" Margin="0,0,1,0" VerticalAlignment="Bottom" Background="#8B5CF6"
                                            Height="{Binding Percent, Converter={StaticResource PercentToHeight}, ConverterParameter=80}"
                                            ToolTip="{Binding Percent, StringFormat={}{0:F0}%}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: top processes -->
            <Border Grid.Column="2" Style="{DynamicResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Top Memory Processes" Style="{DynamicResource SubheadingText}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,3" FontSize="11" Margin="0,0,6,0"
                                    Command="{Binding SelectAllCommand}">
                                <TextBlock Text="All"/>
                            </Button>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,3" FontSize="11" Margin="0,0,6,0"
                                    Command="{Binding SelectNoneCommand}">
                                <TextBlock Text="None"/>
                            </Button>
                            <Button Style="{DynamicResource SecondaryButton}" Padding="8,3" FontSize="11"
                                    Command="{Binding RefreshProcessesCommand}">
                                <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <ListView Style="{DynamicResource ModernListView}" ItemsSource="{Binding Processes}"
                              MaxHeight="420"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="30">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{DynamicResource ModernCheckBox}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Process" Width="160" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="PID" Width="55" DisplayMemberBinding="{Binding Pid}"/>
                                <GridViewColumn Header="Memory" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MemDisplay}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="% RAM" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PercentDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
