<UserControl x:Class="WinOptimizerHub.Views.TelemetryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Windows Telemetry Disabler"/>
                <TextBlock Text="{Binding SummaryText}" Style="{DynamicResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource DangerButton}"
                    Command="{Binding ApplyAllCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72E;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Disable Selected"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="5" Style="{DynamicResource SecondaryButton}"
                    Command="{Binding RevertAllCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE777;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Restore Defaults"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Warning -->
        <Border Background="#0AF59E0B" CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                BorderBrush="#30F59E0B" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" FontFamily="{DynamicResource IconFont}"
                           FontSize="16" Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="These changes modify Windows registry and services. A system restore point is recommended before applying."
                           Style="{DynamicResource SecondaryText}" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Progress -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Select All / None -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding HasItems, Converter={StaticResource BoolVis}}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{DynamicResource SecondaryButton}" Padding="10,4" Click="TelemetrySelectAll_Click">
                    <TextBlock Text="Select All" FontSize="12"/>
                </Button>
                <Button Style="{DynamicResource SecondaryButton}" Padding="10,4" Margin="8,0,0,0"
                        Click="TelemetrySelectNone_Click">
                    <TextBlock Text="Select None" FontSize="12"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Items grouped by category -->
        <Border Style="{DynamicResource Card}">
            <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GroupedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <Border BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="0,0,0,2" Padding="0,0,0,6" Margin="0,4,0,8">
                                    <TextBlock Text="{Binding Header}" FontWeight="Bold" FontSize="13"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{DynamicResource SmallCard}" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              Style="{DynamicResource ModernCheckBox}"
                                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Style="{DynamicResource SecondaryText}"
                                                                   Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                                                            Margin="12,0,8,0" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrentlyEnabled}" Value="True">
                                                                        <Setter Property="Background" Value="#1AEF4444"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCurrentlyEnabled}" Value="False">
                                                                        <Setter Property="Background" Value="#1A22C55E"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Active"/>
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrentlyEnabled}" Value="False">
                                                                            <Setter Property="Text" Value="Disabled"/>
                                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <Button Grid.Column="3" Style="{DynamicResource SecondaryButton}"
                                                            Padding="10,4" FontSize="11"
                                                            Click="ToggleTelemetryItem_Click"
                                                            Tag="{Binding}" VerticalAlignment="Center">
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Disable"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrentlyEnabled}" Value="False">
                                                                            <Setter Property="Text" Value="Enable"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
