<UserControl x:Class="WinOptimizerHub.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Startup Manager"/>
                <TextBlock Style="{DynamicResource SecondaryText}"
                           Text="Manage programs that run automatically at Windows startup" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}" Click="RefreshStartup_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <Border Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="{Binding ItemCount}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,12"/>
                <ListView x:Name="StartupList"
                          Style="{DynamicResource ModernListView}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          MaxHeight="540"
                          SelectionChanged="StartupList_SelectionChanged"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Item">
                    <ListView.Resources>
                        <Style x:Key="SmallToggle" TargetType="ToggleButton">
                            <Setter Property="Width" Value="30"/>
                            <Setter Property="Height" Value="16"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="track" Width="30" Height="16" CornerRadius="8"
                                                Background="{DynamicResource TextMutedBrush}">
                                            <Ellipse x:Name="knob" Width="12" Height="12" Fill="White"
                                                     HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="knob" Property="Margin" Value="0,0,2,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource ModernListViewItem}">
                            <Setter Property="Padding" Value="3,2"/>
                            <Setter Property="MinHeight" Value="26"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Enable at Startup"      Click="StartupCtx_Enable_Click"/>
                            <MenuItem Header="Disable at Startup"     Click="StartupCtx_Disable_Click"/>
                            <Separator/>
                            <MenuItem Header="Copy Image Path"        Click="StartupCtx_CopyPath_Click"/>
                            <MenuItem Header="Copy Registry Key"      Click="StartupCtx_CopyRegKey_Click"/>
                            <Separator/>
                            <MenuItem Header="Jump to Registry Entry" Click="StartupCtx_JumpToEntry_Click"/>
                            <Separator/>
                            <MenuItem Header="Remove from Startup"    Click="StartupCtx_Delete_Click" Foreground="#EF4444"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgPrimaryBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="0,0,0,2" Padding="6,6,0,4" Margin="0,8,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Items[0].CategoryIcon}"
                                                       FontFamily="{DynamicResource IconFont}" FontSize="15"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <StackPanel>
                                                    <ContentPresenter/>
                                                    <ItemsPresenter/>
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="46">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      Click="StartupToggle_Click"
                                                      Style="{StaticResource SmallToggle}"
                                                      Tag="{Binding}"
                                                      HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding IconSource}" Width="18" Height="18"
                                                   Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"
                                                   VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" ToolTip="{Binding Command}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Description" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" ToolTip="{Binding Description}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Publisher" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Publisher}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" ToolTip="{Binding Publisher}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Image Path" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Command}" FontSize="11" FontFamily="{DynamicResource MonoFont}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" ToolTip="{Binding Command}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Registry Key" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RegistryKey}" FontSize="11" FontFamily="{DynamicResource MonoFont}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Center" ToolTip="{Binding RegistryKey}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
