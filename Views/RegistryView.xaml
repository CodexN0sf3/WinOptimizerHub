<UserControl x:Class="WinOptimizerHub.Views.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <converters:StringToColorBrushConverter x:Key="StringBrush"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Registry Cleaner"/>
                <TextBlock Style="{DynamicResource SecondaryText}"
                           Text="Find and remove invalid, orphaned registry entries" Margin="0,4,0,0"/>
            </StackPanel>
            <CheckBox Grid.Column="1" x:Name="DeepScanCheck" Content="Deep scan"
                      Style="{DynamicResource ModernCheckBox}" VerticalAlignment="Center"/>
            <Button Grid.Column="3" Style="{DynamicResource SecondaryButton}" Click="ScanRegistry_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Scan Registry"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="5" Style="{DynamicResource DangerButton}"
                    Command="{Binding CleanCommand}"
                    IsEnabled="{Binding HasIssues}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Fix Selected"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Style="{DynamicResource Card}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource BodyText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Select All / None toolbar -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding HasIssues, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Style="{DynamicResource SecondaryButton}" Padding="10,4" Click="RegistrySelectAll_Click">
                    <TextBlock Text="Select All" FontSize="12"/>
                </Button>
                <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}" Padding="10,4" Margin="8,0,0,0"
                        Click="RegistrySelectNone_Click">
                    <TextBlock Text="Select None" FontSize="12"/>
                </Button>
                <TextBlock Grid.Column="2" Text="{Binding SummaryText}" Style="{DynamicResource SecondaryText}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBlock Grid.Column="3" Text="{Binding IssueCount}" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Issues ListView grouped by IssueType -->
        <Border Style="{DynamicResource Card}"
                Visibility="{Binding HasIssues, Converter={StaticResource BoolVis}}">
            <ListView x:Name="RegistryList"
                      Style="{DynamicResource ModernListView}"
                      ItemContainerStyle="{DynamicResource ModernListViewItem}"
                      MaxHeight="480"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionChanged="RegistryList_SelectionChanged"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Item">
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPrimaryBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="0,0,0,2"
                                        Padding="4,6,0,4" Margin="0,8,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="10"
                                                Padding="7,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ItemCount}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <ContentPresenter/>
                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="36">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{DynamicResource ModernCheckBox}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Key Path" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding KeyPath}" FontSize="11" FontFamily="{DynamicResource MonoFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" ToolTip="{Binding KeyPath}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Value" Width="140" DisplayMemberBinding="{Binding ValueName}"/>
                        <GridViewColumn Header="Description" Width="360">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{Binding SafetyColor, Converter={StaticResource StringBrush}}"
                                               ToolTip="{Binding Description}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Empty state -->
        <Border Style="{DynamicResource Card}"
                Visibility="{Binding HasIssues, Converter={StaticResource InvBoolVis}}">
            <StackPanel HorizontalAlignment="Center" Margin="40">
                <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}"
                           FontSize="48" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Text="Click 'Scan Registry' to find issues"
                           Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
