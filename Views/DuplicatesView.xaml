<UserControl x:Class="WinOptimizerHub.Views.DuplicatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Duplicate File Finder"/>
                <TextBlock Text="{Binding SummaryText}" Style="{DynamicResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                    Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Scan"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource DangerButton}"
                    Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding HasGroups}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Delete Marked"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Path + Keep strategy -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Path:" VerticalAlignment="Center" Style="{DynamicResource SecondaryText}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchPath, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBox}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Style="{DynamicResource SecondaryButton}"
                        Command="{Binding BrowseCommand}" Padding="10,6" Margin="8,0,0,0">
                    <TextBlock Text="&#xE8DA;" FontFamily="{DynamicResource IconFont}" FontSize="14"/>
                </Button>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Keep:" Style="{DynamicResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton Content="Oldest"     Margin="0,0,10,0" IsChecked="{Binding StrategyKeepOldest}" Style="{DynamicResource ModernRadioButton}" VerticalAlignment="Center"/>
                    <RadioButton Content="Newest"     Margin="0,0,10,0" IsChecked="{Binding StrategyKeepNewest}" Style="{DynamicResource ModernRadioButton}" VerticalAlignment="Center"/>
                    <RadioButton Content="First found"               IsChecked="{Binding StrategyKeepFirst}"  Style="{DynamicResource ModernRadioButton}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                    <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}"
                        Command="{Binding CancelCommand}" Margin="16,0,0,0"
                        VerticalAlignment="Center" Padding="10,6">
                    <TextBlock Text="Cancel" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- Results TreeView — populated in code-behind via RebuildDuplicateTree -->
        <Border Style="{DynamicResource Card}">
            <TreeView x:Name="DuplicateTree"
                      Background="Transparent" BorderThickness="0" MaxHeight="460"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>
    </StackPanel>
</UserControl>
