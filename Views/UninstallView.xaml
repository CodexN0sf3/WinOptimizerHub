<UserControl x:Class="WinOptimizerHub.Views.UninstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
        <converters:StringToColorBrushConverter x:Key="StringBrush"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Uninstall Manager"/>
                <TextBlock Text="{Binding ProgramCount}" Style="{DynamicResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}" Click="RefreshPrograms_Click"
                    Margin="0,0,8,0" IsEnabled="{Binding IsUninstalling, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource DangerButton}" Click="UninstallProgram_Click"
                    IsEnabled="{Binding IsUninstalling, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8E6;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Uninstall Selected"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="5" Style="{DynamicResource SecondaryButton}" Click="ForceUninstall_Click"
                    IsEnabled="{Binding IsUninstalling, Converter={StaticResource InvBool}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Force Uninstall"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search + Tab switcher -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center" MinWidth="220" FontSize="13">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock Text="Search programs..." Foreground="{DynamicResource TextMutedBrush}"
                                                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="6" Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="TabWin32Btn" Content="Win32"   Style="{DynamicResource SecondaryButton}" Padding="12,5" FontSize="12" Click="TabWin32_Click"/>
                        <Button x:Name="TabStoreBtn" Content="⊞ Store" Style="{DynamicResource SecondaryButton}" Padding="12,5" FontSize="12" Click="TabStore_Click" Margin="2,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Progress during uninstall -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding IsUninstalling, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Loading WinApps indicator -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,12"
                Visibility="{Binding LoadingWinApps, Converter={StaticResource BoolVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="13"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Loading Windows Store apps via PowerShell..." Style="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Programs list -->
        <Border Style="{DynamicResource Card}">
            <ListView x:Name="ProgramList"
                      Style="{DynamicResource ModernListView}"
                      ItemsSource="{Binding Programs}"
                      MaxHeight="480"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionChanged="ProgramList_SelectionChanged"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Item">
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPrimaryBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="0,0,0,2" Padding="6,6,0,4" Margin="0,8,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="10"
                                                Padding="7,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ItemCount}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel><ContentPresenter/><ItemsPresenter/></StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Uninstall"              Click="UninstallProgram_Click"/>
                        <MenuItem Header="Open Install Folder"    Click="OpenInstallFolder_Click"/>
                        <Separator/>
                        <MenuItem Header="Copy Name"              Click="CopyProgramName_Click"/>
                        <MenuItem Header="Copy Uninstall String"  Click="CopyUninstallString_Click"/>
                        <Separator/>
                        <MenuItem Header="⚠ Force Uninstall"     Click="ForceUninstall_Click"/>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Type" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="5,2"
                                            Background="{Binding TypeColor, Converter={StaticResource StringBrush}}">
                                        <TextBlock Text="{Binding TypeBadge}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Name"      Width="220" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Publisher" Width="160" DisplayMemberBinding="{Binding Publisher}"/>
                        <GridViewColumn Header="Version"   Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Version}" FontSize="11"
                                               FontFamily="{DynamicResource MonoFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Installed" Width="110" DisplayMemberBinding="{Binding InstallDate}"/>
                        <GridViewColumn Header="Size"      Width="90"  DisplayMemberBinding="{Binding SizeDisplay}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </StackPanel>
</UserControl>
