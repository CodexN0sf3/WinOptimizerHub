<UserControl x:Class="WinOptimizerHub.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Junk File Cleaner"/>
                <TextBlock Style="{DynamicResource SecondaryText}"
                           Text="Scan and remove temporary files, caches and junk" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}" Command="{Binding ScanCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}"
                               FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Scan" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource PrimaryButton}"
                    Command="{Binding CleanCommand}"
                    IsEnabled="{Binding HasFolders}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}"
                               FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Clean Selected" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Progress -->
        <Border Style="{DynamicResource Card}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource BodyText}" Margin="0,0,0,8"/>
                <ProgressBar Style="{DynamicResource ModernProgressBar}" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Summary -->
        <Border Style="{DynamicResource Card}"
                Visibility="{Binding HasFolders, Converter={StaticResource BoolVis}}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalSize}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Found" Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FileCount}" FontSize="28" FontWeight="Bold"
                               Foreground="#F59E0B" HorizontalAlignment="Center"/>
                    <TextBlock Text="Files Found" Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CategoryCount}" FontSize="28" FontWeight="Bold"
                               Foreground="#22C55E" HorizontalAlignment="Center"/>
                    <TextBlock Text="Categories" Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results list -->
        <Border Style="{DynamicResource Card}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Scan Results" Style="{DynamicResource SubheadingText}"/>
                    <Button Style="{DynamicResource GhostButton}" Margin="8,0,0,0"
                            Command="{Binding SelectAllCommand}" Padding="8,4">
                        <TextBlock Text="Select All" Style="{DynamicResource SecondaryText}"/>
                    </Button>
                    <Button Style="{DynamicResource GhostButton}" Margin="4,0,0,0"
                            Command="{Binding DeselectAllCommand}" Padding="8,4">
                        <TextBlock Text="Deselect All" Style="{DynamicResource SecondaryText}"/>
                    </Button>
                    <!-- Cleaning mode selector (moved here from header bar) -->
                    <StackPanel Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Mode:" Style="{DynamicResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <RadioButton x:Name="ModeSafe" Content="Safe" GroupName="CleanMode"
                                     IsChecked="True" Style="{DynamicResource ModernRadioButton}"
                                     Checked="CleanMode_Changed" Margin="0,0,8,0"
                                     ToolTip="Temp files, caches, crash dumps — always safe"/>
                        <RadioButton x:Name="ModeNormal" Content="Normal" GroupName="CleanMode"
                                     Style="{DynamicResource ModernRadioButton}"
                                     Checked="CleanMode_Changed" Margin="0,0,8,0"
                                     ToolTip="Adds: Prefetch, logs, dev tool caches, app caches"/>
                        <RadioButton x:Name="ModeAggressive" Content="Aggressive" GroupName="CleanMode"
                                     Style="{DynamicResource ModernRadioButton}"
                                     Checked="CleanMode_Changed"
                                     ToolTip="Adds: Windows.old, upgrade leftovers, installer cache — may be several GB"/>
                    </StackPanel>
                </StackPanel>
                <!-- Mode description -->
                <TextBlock Text="{Binding ModeDescription}"
                           Style="{DynamicResource SecondaryText}"
                           Margin="0,0,0,10" FontStyle="Italic"/>
                <ListView Style="{DynamicResource ModernListView}" ItemsSource="{Binding Folders}"
                          MaxHeight="420" SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="ToolTip" Value="{Binding Description}"/>
                            <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="36">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Style="{DynamicResource ModernCheckBox}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="210" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Category" Width="110" DisplayMemberBinding="{Binding Category}"/>
                            <GridViewColumn Header="Files" Width="60" DisplayMemberBinding="{Binding FileCount}"/>
                            <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeDisplay, Mode=OneWay}"/>
                            <GridViewColumn Header="Mode" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MinMode}" Value="Safe">
                                                            <Setter Property="Text" Value="Safe"/>
                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding MinMode}" Value="Normal">
                                                            <Setter Property="Text" Value="Normal"/>
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding MinMode}" Value="Aggressive">
                                                            <Setter Property="Text" Value="Aggressive"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Path" Width="280" DisplayMemberBinding="{Binding Path}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <TextBlock Text="Click 'Scan' to find junk files"
                           Visibility="{Binding HasFolders, Converter={StaticResource InvBoolVis}}"
                           Style="{DynamicResource SecondaryText}" Margin="0,16"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
