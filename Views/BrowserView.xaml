<UserControl x:Class="WinOptimizerHub.Views.BrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinOptimizerHub.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource HeadingText}" Text="Browser Cache Cleaner"/>
                <TextBlock Style="{DynamicResource SecondaryText}"
                           Text="Detect and clean caches from all installed browsers" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}" Command="{Binding ScanCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Detect Browsers"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{DynamicResource PrimaryButton}"
                    Click="CleanBrowsers_Click"
                    IsEnabled="{Binding HasBrowsers}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Clean Cache"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Options -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Also clean:" Style="{DynamicResource BodyText}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <CheckBox x:Name="CleanBrowserHistory" Content="History"
                          Style="{DynamicResource ModernCheckBox}" Margin="0,0,16,0"/>
                <CheckBox x:Name="CleanBrowserCookies" Content="Cookies"
                          Style="{DynamicResource ModernCheckBox}"/>
            </StackPanel>
        </Border>

        <!-- Browser list -->
        <Border Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Detected Browsers" Style="{DynamicResource SubheadingText}" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Browsers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{DynamicResource SmallCard}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{DynamicResource ModernCheckBox}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" MinWidth="140"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CachePathDisplay}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" Margin="16,0"
                                               ToolTip="{Binding CachePathDisplay}"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding CacheSizeDisplay}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="16,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Visibility="{Binding HasBrowsers, Converter={StaticResource InvBoolVis}}"
                           Text="Click 'Detect Browsers' to scan your system"
                           Style="{DynamicResource SecondaryText}" HorizontalAlignment="Center"
                           Margin="0,16"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
