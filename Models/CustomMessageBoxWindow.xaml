<Window x:Class="WinOptimizerHub.Models.CustomMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        SizeToContent="WidthAndHeight"
        MinWidth="400" MaxWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Effect="{DynamicResource CardShadow}">
        <StackPanel Margin="28,24,28,20">

            <!-- Title row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border x:Name="IconBorder"
                        Width="36" Height="36" CornerRadius="8"
                        Background="{DynamicResource AccentBrush}"
                        Margin="0,0,14,0" VerticalAlignment="Top">
                    <TextBlock x:Name="IconGlyph"
                               Text="&#xE897;"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="18" Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TitleText"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="460"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="50,0,0,24"
                       MaxWidth="460"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <Button x:Name="BtnNo"
                        Content="Cancel"
                        Style="{DynamicResource SecondaryButton}"
                        MinWidth="88" Height="34"
                        Margin="0,0,10,0"
                        Click="BtnNo_Click"/>
                <Button x:Name="BtnYes"
                        Content="Confirm"
                        Style="{DynamicResource PrimaryButton}"
                        MinWidth="88" Height="34"
                        Click="BtnYes_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
